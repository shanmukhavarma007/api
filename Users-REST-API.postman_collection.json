    {
      "name": "Search Users",
      "item": [
        {
          "name": "Search by Name",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/users/search?name=John",
              "host": ["{{baseUrl}}"],
              "path": ["users", "search"],
              "query": [
                {
                  "key": "name",
                  "value": "John"
                }
              ]
            }
          }
        },
        {
          "name": "Search by Role",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/users/search?role=admin",
              "host": ["{{baseUrl}}"],
              "path": ["users", "search"],
              "query": [
                {
                  "key": "role",
                  "value": "admin"
                }
              ]
            }
          }
        },
        {
          "name": "Search by Status",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/users/search?status=active",
              "host": ["{{baseUrl}}"],
              "path": ["users", "search"],
              "query": [
                {
                  "key": "status",
                  "value": "active"
                }
              ]
            }
          }
        },
        {
          "name": "Search - Multiple Filters",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/users/search?role=admin&status=active",
              "host": ["{{baseUrl}}"],
              "path": ["users", "search"],
              "query": [
                {
                  "key": "role",
                  "value": "admin"
                },
                {
                  "key": "status",
